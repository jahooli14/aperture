{
  "name": "aperture",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.api.json && vite build",
    "build:analyze": "npm run build && node scripts/analyze-bundle.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ api/",
    "type-check": "tsc --noEmit",
    "seed": "tsx scripts/polymath/seed-test-data.ts",
    "scan": "tsx scripts/polymath/capability-scanner.ts",
    "synthesize": "tsx scripts/polymath/synthesis.ts",
    "strengthen": "tsx scripts/polymath/strengthen-nodes.ts",
    "backfill:embeddings": "tsx scripts/backfill-embeddings.ts",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel"
  },
  "dependencies": {
